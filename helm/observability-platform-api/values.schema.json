{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "loki": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "hostname": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "parentRefs": {
                    "type": "array"
                },
                "basicAuth": {
                    "type": "object",
                    "description": "Basic Auth config for Loki routes. When set alongside JWT, routes accept either credential type.",
                    "properties": {
                        "secretName": {
                            "type": "string",
                            "description": "Name of the .htpasswd Secret in the loki namespace."
                        }
                    }
                },
                "read": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } }
                    }
                },
                "write": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } },
                        "stripPrefixPaths": { "type": "array", "items": { "type": "string" } },
                        "grpc": {
                            "type": "object",
                            "properties": {
                                "backendService": { "type": "string" },
                                "backendPort": { "type": "integer" }
                            }
                        }
                    }
                }
            }
        },
        "mimir": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "hostname": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "parentRefs": {
                    "type": "array"
                },
                "basicAuth": {
                    "type": "object",
                    "description": "Basic Auth config for Mimir routes. When set alongside JWT, routes accept either credential type.",
                    "properties": {
                        "secretName": {
                            "type": "string",
                            "description": "Name of the .htpasswd Secret in the mimir namespace."
                        }
                    }
                },
                "read": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } }
                    }
                },
                "write": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } },
                        "stripPrefixPaths": { "type": "array", "items": { "type": "string" } }
                    }
                }
            }
        },
        "tempo": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "hostname": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "parentRefs": {
                    "type": "array"
                },
                "basicAuth": {
                    "type": "object",
                    "description": "Basic Auth config for Tempo routes. When set alongside JWT, routes accept either credential type.",
                    "properties": {
                        "secretName": {
                            "type": "string",
                            "description": "Name of the .htpasswd Secret in the tempo namespace."
                        }
                    }
                },
                "read": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } },
                        "grpc": {
                            "type": "object",
                            "properties": {
                                "backendService": { "type": "string" },
                                "backendPort": { "type": "integer" }
                            }
                        }
                    }
                },
                "write": {
                    "type": "object",
                    "properties": {
                        "paths": { "type": "array", "items": { "type": "string" } },
                        "stripPrefixPaths": { "type": "array", "items": { "type": "string" } }
                    }
                }
            }
        },
        "ingresses": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "hosts": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "host": {
                                    "type": "string"
                                },
                                "paths": {
                                    "type": "array"
                                }
                            }
                        }
                    },
                    "ingressClassName": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "namespace": {
                        "type": "string"
                    },
                    "service": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "port": {
                                "type": "integer"
                            }
                        }
                    }
                }
            }
        },
        "auth": {
            "type": "object",
            "properties": {
                "jwt": {
                    "type": "object",
                    "description": "JWT validation config for all routes. Supports multiple OIDC providers.",
                    "properties": {
                        "providers": {
                            "type": "array",
                            "description": "List of trusted JWT providers. Required when any service is enabled.",
                            "items": {
                                "type": "object",
                                "required": ["name", "issuer", "remoteJWKS"],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "issuer": {
                                        "type": "string"
                                    },
                                    "remoteJWKS": {
                                        "type": "object",
                                        "properties": {
                                            "uri": {
                                                "type": "string"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "name": {
            "type": "string"
        },
        "serviceType": {
            "type": "string"
        }
    }
}
